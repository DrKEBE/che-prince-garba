# backend\.env

# ===== CORE =====
ENVIRONMENT=development
DEV_MODE=true
DEBUG=true

# ===== DATABASE =====
#DATABASE_URL=sqlite:///che_prince_garba.db/.
DATABASE_URL=sqlite:///C:/Users/DrKEBE/CodeKeb/che-prince-garba/backend/che_prince_garba.db
# ===== JWT =====
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== CORS =====
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://192.168.1.13:8000"]

# ===== DEV =====
DEV_TOKEN=fake-token-admin
DEV_USER_ID=1

# ===== APP =====
APP_NAME="Luxe Beauté Management"
APP_VERSION=2.0.0
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760